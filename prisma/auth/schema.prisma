generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum UserRole {
  USER
  ADMIN
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum TokenType {
  REFRESH
  EMAIL_VERIFY
  PASSWORD_RESET
  TWO_FA_TEMP
}


model User {
  id               String         @id @default(cuid())
  email            String         @unique @db.VarChar(255)
  passwordHash     String         @db.VarChar(255)

  role             UserRole       @default(USER)

  isEmailVerified  Boolean        @default(false)
  emailVerifiedAt  DateTime?

  isTwoFaEnabled   Boolean        @default(false)

  kycStatus        KycStatus      @default(NOT_SUBMITTED)

  lastLoginAt      DateTime?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Relations
  trustedDevices TrustedDevice[]
  twoFaSecret      TwoFaSecret?
  sessions         Session[]
  authTokens       AuthToken[]
  loginAttempts    LoginAttempt[]
}

model TrustedDevice {
  id          String    @id @default(cuid())
  userId      String

  tokenHash   String    @unique @db.VarChar(255)
  userAgent   String?   @db.Text
  ipAddress   String?   @db.VarChar(64)

  expiresAt   DateTime
  revokedAt   DateTime?

  createdAt   DateTime  @default(now())
  lastUsedAt   DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model TwoFaSecret {
  id               String    @id @default(cuid())
  userId           String    @unique

  secretEncrypted  String    @db.Text
  backupCodesHash  String[]

  isVerified       Boolean   @default(false)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model Session {
  id               String    @id @default(cuid())
  userId           String

  refreshTokenHash String    @unique @db.VarChar(255)

  userAgent        String?   @db.Text
  ipAddress        String?   @db.VarChar(64)
  deviceName       String?   @db.VarChar(120)
  location         String?   @db.VarChar(120)

  expiresAt        DateTime
  revokedAt        DateTime?
  lastActivityAt   DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}


model AuthToken {
  id               String    @id @default(cuid())
  userId           String

  type             TokenType
  tokenHash        String    @unique @db.VarChar(255)

  expiresAt        DateTime
  usedAt           DateTime?

  createdAt        DateTime  @default(now())

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
  @@index([tokenHash, type])
}


model LoginAttempt {
  id               String    @id @default(cuid())

  userId           String?
  email            String    @db.VarChar(255)

  ipAddress        String?   @db.VarChar(64)
  userAgent        String?   @db.Text

  success          Boolean
  reason           String?   @db.VarChar(120)

  isBlocked        Boolean   @default(false)

  createdAt        DateTime  @default(now())

  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([userId, createdAt])
}