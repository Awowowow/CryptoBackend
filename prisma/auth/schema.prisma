generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum TokenType {
  REFRESH
  EMAIL_VERIFY
  PASSWORD_RESET
  TWO_FA_TEMP
}

enum KycDocumentType {
  PASSPORT
  NATIONAL_ID
  DRIVING_LICENSE
}

enum KycFileType {
  ID_FRONT
  ID_BACK
  PROOF_OF_ADDRESS
  SELFIE
}

enum WalletOwnerType {
  USER
  SYSTEM
}

enum WalletAccountType {
  AVAILABLE
  LOCKED
  CUSTODY
  FEE_REVENUE
}

enum LedgerTransactionType {
  DEPOSIT
  WITHDRAWAL
  FUNDS_LOCK
  FUNDS_UNLOCK
  TRADE_SETTLEMENT
  FEE_COLLECTION
  ADMIN_ADJUSTMENT
}

enum DepositStatus {
  DETECTED
  CONFIRMING
  CONFIRMED
  CREDITED
  REJECTED
}

enum WithdrawalStatus {
  REQUESTED
  SECURITY_CHECKED
  FUNDS_LOCKED
  PENDING_REVIEW
  APPROVED
  PROCESSING
  SUBMITTED
  BROADCASTED
  CONFIRMED
  COMPLETED
  FAILED
  REJECTED
  CANCELLED
}

enum CustodyProviderType {
  BITGO
}

enum WithdrawalAddressStatus {
  PENDING_VERIFICATION
  ACTIVE
  DISABLED
  REJECTED
}

enum CustodyWebhookEventStatus {
  RECEIVED
  VERIFIED
  PROCESSING
  PROCESSED
  FAILED
  REJECTED
}

enum DomainEventOutboxStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
}

enum TradingPairStatus {
  ACTIVE
  DISABLED
}

enum TradeOrderSide {
  BUY
  SELL
}

enum TradeOrderType {
  LIMIT
  MARKET
}

enum TradeOrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  REJECTED
  EXPIRED
}

enum TradeOrderTimeInForce {
  GTC
  IOC
  FOK
}

enum TradeLiquidityRole {
  MAKER
  TAKER
}

model Asset {
  id       String  @id @default(cuid())
  symbol   String  @unique @db.VarChar(20)
  name     String  @db.VarChar(120)
  decimals Int
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  walletAccounts WalletAccount[]
  ledgerEntries  LedgerEntry[]
  assetNetworks  AssetNetwork[]
  withdrawals    Withdrawal[]

  baseTradingPairs  TradingPair[] @relation("TradingPairBaseAsset")
  quoteTradingPairs TradingPair[] @relation("TradingPairQuoteAsset")

  baseTradeOrders   TradeOrder[] @relation("TradeOrderBaseAsset")
  quoteTradeOrders  TradeOrder[] @relation("TradeOrderQuoteAsset")
  lockedTradeOrders TradeOrder[] @relation("TradeOrderLockedAsset")

  baseTrades      Trade[] @relation("TradeBaseAsset")
  quoteTrades     Trade[] @relation("TradeQuoteAsset")
  buyerFeeTrades  Trade[] @relation("TradeBuyerFeeAsset")
  sellerFeeTrades Trade[] @relation("TradeSellerFeeAsset")
}

model BlockchainNetwork {
  id String @id @default(cuid())

  code String @unique @db.VarChar(40)
  name String @db.VarChar(120)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assetNetworks       AssetNetwork[]
  depositAddresses    DepositAddress[]
  deposits            Deposit[]
  scanCheckpoints     BlockchainScanCheckpoint[]
  withdrawalAddresses WithdrawalAddress[]
  withdrawals         Withdrawal[]
}

model AssetNetwork {
  id String @id @default(cuid())

  assetId   String
  networkId String

  depositEnabled    Boolean @default(true)
  withdrawalEnabled Boolean @default(true)

  minConfirmations Int @default(1)

  contractAddress String? @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  asset   Asset             @relation(fields: [assetId], references: [id], onDelete: Restrict)
  network BlockchainNetwork @relation(fields: [networkId], references: [id], onDelete: Restrict)

  depositAddresses    DepositAddress[]
  deposits            Deposit[]
  withdrawalAddresses WithdrawalAddress[]
  withdrawals         Withdrawal[]

  @@unique([assetId, networkId])
  @@index([networkId])
}

model WalletAccount {
  id      String  @id @default(cuid())
  userId  String?
  assetId String

  ownerType        WalletOwnerType
  type             WalletAccountType
  systemAccountKey String?           @db.VarChar(120)
  label            String?           @db.VarChar(120)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Restrict)

  balance       WalletBalance?
  ledgerEntries LedgerEntry[]

  @@unique([userId, assetId, type])
  @@unique([systemAccountKey, assetId, type])
  @@index([assetId])
  @@index([ownerType, type])
}

model DepositAddress {
  id String @id @default(cuid())

  userId         String
  assetNetworkId String
  networkId      String

  address String  @db.VarChar(255)
  memo    String? @db.VarChar(255)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetNetwork AssetNetwork      @relation(fields: [assetNetworkId], references: [id], onDelete: Restrict)
  network      BlockchainNetwork @relation(fields: [networkId], references: [id], onDelete: Restrict)

  deposits Deposit[]

  @@unique([userId, assetNetworkId])
  @@unique([networkId, address, memo])
  @@index([userId])
  @@index([assetNetworkId])
  @@index([networkId])
}

model Deposit {
  id String @id @default(cuid())

  userId           String
  assetNetworkId   String
  networkId        String
  depositAddressId String

  txHash     String @db.VarChar(255)
  eventIndex Int    @default(0)

  amount Decimal @db.Decimal(36, 18)

  status        DepositStatus @default(DETECTED)
  confirmations Int           @default(0)

  detectedAt  DateTime  @default(now())
  confirmedAt DateTime?
  creditedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetNetwork   AssetNetwork      @relation(fields: [assetNetworkId], references: [id], onDelete: Restrict)
  network        BlockchainNetwork @relation(fields: [networkId], references: [id], onDelete: Restrict)
  depositAddress DepositAddress    @relation(fields: [depositAddressId], references: [id], onDelete: Restrict)

  @@unique([networkId, txHash, eventIndex])
  @@index([userId])
  @@index([assetNetworkId])
  @@index([networkId])
  @@index([depositAddressId])
  @@index([status])
}

model User {
  id           String @id @default(cuid())
  email        String @unique @db.VarChar(255)
  passwordHash String @db.VarChar(255)

  role UserRole @default(USER)

  isEmailVerified Boolean   @default(false)
  emailVerifiedAt DateTime?

  isTwoFaEnabled Boolean @default(false)

  kycStatus KycStatus @default(NOT_SUBMITTED)

  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  trustedDevices         TrustedDevice[]
  twoFaSecret            TwoFaSecret?
  sessions               Session[]
  authTokens             AuthToken[]
  loginAttempts          LoginAttempt[]
  kycSubmissions         KycSubmission[]
  walletAccounts         WalletAccount[]
  depositAddresses       DepositAddress[]
  deposits               Deposit[]
  reviewedKycSubmissions KycSubmission[]      @relation("KycReviewedBy")
  kycAuditLogs           KycAuditLog[]        @relation("KycAuditActor")
  withdrawalAddresses    WithdrawalAddress[]
  withdrawals            Withdrawal[]         @relation("UserWithdrawals")
  reviewedWithdrawals    Withdrawal[]         @relation("WithdrawalReviewedBy")
  withdrawalAuditLogs    WithdrawalAuditLog[] @relation("WithdrawalAuditActor")
  tradeOrders            TradeOrder[]
  buyTrades              Trade[]              @relation("TradeBuyer")
  sellTrades             Trade[]              @relation("TradeSeller")
}

model TrustedDevice {
  id     String @id @default(cuid())
  userId String

  tokenHash String  @unique @db.VarChar(255)
  userAgent String? @db.Text
  ipAddress String? @db.VarChar(64)

  expiresAt DateTime
  revokedAt DateTime?

  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model TwoFaSecret {
  id     String @id @default(cuid())
  userId String @unique

  secretEncrypted String   @db.Text
  backupCodesHash String[]

  isVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id     String @id @default(cuid())
  userId String

  refreshTokenHash String @unique @db.VarChar(255)

  userAgent  String? @db.Text
  ipAddress  String? @db.VarChar(64)
  deviceName String? @db.VarChar(120)
  location   String? @db.VarChar(120)

  expiresAt      DateTime
  revokedAt      DateTime?
  lastActivityAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuthToken {
  id     String @id @default(cuid())
  userId String

  type      TokenType
  tokenHash String    @unique @db.VarChar(255)

  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
  @@index([tokenHash, type])
}

model LoginAttempt {
  id String @id @default(cuid())

  userId String?
  email  String  @db.VarChar(255)

  ipAddress String? @db.VarChar(64)
  userAgent String? @db.Text

  success Boolean
  reason  String? @db.VarChar(120)

  isBlocked Boolean @default(false)

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([userId, createdAt])
}

model KycSubmission {
  id     String @id @default(cuid())
  userId String

  status KycStatus @default(PENDING)

  legalFirstName String   @db.VarChar(120)
  legalLastName  String   @db.VarChar(120)
  dateOfBirth    DateTime

  country      String  @db.VarChar(80)
  addressLine1 String  @db.VarChar(255)
  addressLine2 String? @db.VarChar(255)
  city         String  @db.VarChar(120)
  postalCode   String  @db.VarChar(40)

  documentType   KycDocumentType
  documentNumber String?         @db.VarChar(120)

  rejectionReason String? @db.Text

  submittedAt      DateTime  @default(now())
  reviewedAt       DateTime?
  reviewedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?         @relation("KycReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  documents  KycDocument[]
  auditLogs  KycAuditLog[]

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
  @@index([reviewedByUserId])
}

model KycDocument {
  id           String @id @default(cuid())
  submissionId String

  fileType KycFileType
  fileName String      @db.VarChar(255)
  filePath String      @db.Text
  mimeType String      @db.VarChar(120)
  fileSize Int

  createdAt DateTime @default(now())

  submission KycSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, fileType])
  @@index([submissionId])
  @@index([fileType])
}

model KycAuditLog {
  id           String  @id @default(cuid())
  submissionId String
  actorUserId  String?

  action     String     @db.VarChar(80)
  fromStatus KycStatus?
  toStatus   KycStatus?
  reason     String?    @db.Text

  createdAt DateTime @default(now())

  submission KycSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  actor      User?         @relation("KycAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([submissionId])
  @@index([actorUserId])
  @@index([createdAt])
}

model WalletBalance {
  id              String @id @default(cuid())
  walletAccountId String @unique

  balance Decimal @default(0) @db.Decimal(36, 18)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  walletAccount WalletAccount @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)
}

model LedgerTransaction {
  id String @id @default(cuid())

  type           LedgerTransactionType
  idempotencyKey String                @unique @db.VarChar(180)

  referenceType String? @db.VarChar(80)
  referenceId   String? @db.VarChar(180)
  description   String? @db.Text

  createdAt DateTime @default(now())

  entries LedgerEntry[]

  @@index([type])
  @@index([referenceType, referenceId])
  @@index([createdAt])
}

model LedgerEntry {
  id                  String @id @default(cuid())
  ledgerTransactionId String
  walletAccountId     String
  assetId             String

  amount Decimal @db.Decimal(36, 18)

  createdAt DateTime @default(now())

  ledgerTransaction LedgerTransaction @relation(fields: [ledgerTransactionId], references: [id], onDelete: Restrict)
  walletAccount     WalletAccount     @relation(fields: [walletAccountId], references: [id], onDelete: Restrict)
  asset             Asset             @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@index([ledgerTransactionId])
  @@index([walletAccountId])
  @@index([assetId])
  @@index([createdAt])
}

model BlockchainScanCheckpoint {
  id String @id @default(cuid())

  scannerKey       String @unique @db.VarChar(120)
  networkId        String
  lastScannedBlock BigInt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  network BlockchainNetwork @relation(fields: [networkId], references: [id], onDelete: Restrict)

  @@index([networkId])
}

model CustodyWebhookEvent {
  id String @id @default(cuid())

  provider        CustodyProviderType
  externalEventId String              @db.VarChar(255)
  eventType       String              @db.VarChar(80)

  walletId   String? @db.VarChar(255)
  transferId String? @db.VarChar(255)
  coin       String? @db.VarChar(40)

  payload Json

  status       CustodyWebhookEventStatus @default(RECEIVED)
  errorMessage String?                   @db.Text

  receivedAt  DateTime  @default(now())
  verifiedAt  DateTime?
  processedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, externalEventId])
  @@index([provider, status])
  @@index([transferId])
  @@index([receivedAt])
}

model WithdrawalAddress {
  id String @id @default(cuid())

  userId         String
  assetNetworkId String
  networkId      String

  label   String? @db.VarChar(120)
  address String  @db.VarChar(255)
  memo    String? @db.VarChar(255)

  status WithdrawalAddressStatus @default(PENDING_VERIFICATION)

  verifiedAt DateTime?
  disabledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetNetwork AssetNetwork      @relation(fields: [assetNetworkId], references: [id], onDelete: Restrict)
  network      BlockchainNetwork @relation(fields: [networkId], references: [id], onDelete: Restrict)

  withdrawals Withdrawal[]

  @@unique([userId, assetNetworkId, address, memo])
  @@index([userId])
  @@index([assetNetworkId])
  @@index([networkId])
  @@index([status])
}

model Withdrawal {
  id String @id @default(cuid())

  userId              String
  assetId             String
  assetNetworkId      String
  networkId           String
  withdrawalAddressId String?

  destinationAddress String  @db.VarChar(255)
  destinationMemo    String? @db.VarChar(255)

  amount      Decimal @db.Decimal(36, 18)
  feeAmount   Decimal @default(0) @db.Decimal(36, 18)
  totalAmount Decimal @db.Decimal(36, 18)

  status WithdrawalStatus @default(REQUESTED)

  confirmations         Int @default(0)
  requiredConfirmations Int @default(0)

  idempotencyKey String @unique @db.VarChar(180)

  provider                  CustodyProviderType @default(BITGO)
  providerTransferId        String?             @db.VarChar(255)
  providerTxRequestId       String?             @db.VarChar(255)
  providerPendingApprovalId String?             @db.VarChar(255)
  providerState             String?             @db.VarChar(80)
  txHash                    String?             @db.VarChar(255)

  riskScore            Int     @default(0)
  riskReason           String? @db.Text
  requiresManualReview Boolean @default(false)

  failureReason   String? @db.Text
  rejectionReason String? @db.Text
  cancelledReason String? @db.Text

  requestedAt       DateTime  @default(now())
  securityCheckedAt DateTime?
  fundsLockedAt     DateTime?
  reviewRequestedAt DateTime?
  approvedAt        DateTime?
  processingAt      DateTime?
  submittedAt       DateTime?
  broadcastedAt     DateTime?
  confirmedAt       DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  rejectedAt        DateTime?
  cancelledAt       DateTime?

  reviewedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User               @relation("UserWithdrawals", fields: [userId], references: [id], onDelete: Cascade)
  asset             Asset              @relation(fields: [assetId], references: [id], onDelete: Restrict)
  assetNetwork      AssetNetwork       @relation(fields: [assetNetworkId], references: [id], onDelete: Restrict)
  network           BlockchainNetwork  @relation(fields: [networkId], references: [id], onDelete: Restrict)
  withdrawalAddress WithdrawalAddress? @relation(fields: [withdrawalAddressId], references: [id], onDelete: SetNull)
  reviewedBy        User?              @relation("WithdrawalReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  auditLogs WithdrawalAuditLog[]

  @@unique([provider, providerTransferId])
  @@index([userId])
  @@index([assetId])
  @@index([assetNetworkId])
  @@index([networkId])
  @@index([withdrawalAddressId])
  @@index([status])
  @@index([txHash])
  @@index([requiresManualReview, status])
  @@index([createdAt])
  @@index([providerTxRequestId])
  @@index([providerPendingApprovalId])
}

model WithdrawalAuditLog {
  id String @id @default(cuid())

  withdrawalId String
  actorUserId  String?

  action     String            @db.VarChar(80)
  fromStatus WithdrawalStatus?
  toStatus   WithdrawalStatus?

  reason   String? @db.Text
  metadata Json?

  createdAt DateTime @default(now())

  withdrawal Withdrawal @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)
  actor      User?      @relation("WithdrawalAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([withdrawalId])
  @@index([actorUserId])
  @@index([toStatus])
  @@index([createdAt])
}

model DomainEventOutbox {
  id String @id @default(cuid())

  eventType     String @db.VarChar(120)
  aggregateType String @db.VarChar(80)
  aggregateId   String @db.VarChar(180)

  idempotencyKey String @unique @db.VarChar(180)

  payload Json

  status DomainEventOutboxStatus @default(PENDING)

  attempts    Int       @default(0)
  availableAt DateTime  @default(now())
  lockedAt    DateTime?
  publishedAt DateTime?

  lastError String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, availableAt, createdAt])
  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@index([publishedAt])
}

model TradingPair {
  id String @id @default(cuid())

  symbol String @unique @db.VarChar(40)

  baseAssetId  String
  quoteAssetId String

  status TradingPairStatus @default(ACTIVE)

  priceDecimals    Int @default(8)
  quantityDecimals Int @default(8)

  minBaseQuantity Decimal @default(0) @db.Decimal(36, 18)
  minQuoteAmount  Decimal @default(0) @db.Decimal(36, 18)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  baseAsset  Asset @relation("TradingPairBaseAsset", fields: [baseAssetId], references: [id], onDelete: Restrict)
  quoteAsset Asset @relation("TradingPairQuoteAsset", fields: [quoteAssetId], references: [id], onDelete: Restrict)

  orders  TradeOrder[]
  trades  Trade[]
  candles MarketCandle[]

  @@unique([baseAssetId, quoteAssetId])
  @@index([baseAssetId])
  @@index([quoteAssetId])
  @@index([status])
}

model TradeOrder {
  id String @id @default(cuid())

  userId        String
  tradingPairId String
  baseAssetId   String
  quoteAssetId  String

  side        TradeOrderSide
  type        TradeOrderType
  status      TradeOrderStatus      @default(OPEN)
  timeInForce TradeOrderTimeInForce @default(GTC)

  price Decimal? @db.Decimal(36, 18)

  originalQuantity  Decimal @db.Decimal(36, 18)
  filledQuantity    Decimal @default(0) @db.Decimal(36, 18)
  remainingQuantity Decimal @db.Decimal(36, 18)

  lockedAssetId  String
  lockedAmount   Decimal @db.Decimal(36, 18)
  releasedAmount Decimal @default(0) @db.Decimal(36, 18)

  idempotencyKey String @unique @db.VarChar(180)

  rejectedReason  String? @db.Text
  cancelledReason String? @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  filledAt    DateTime?
  cancelledAt DateTime?
  rejectedAt  DateTime?
  expiredAt   DateTime?

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradingPair TradingPair @relation(fields: [tradingPairId], references: [id], onDelete: Restrict)
  baseAsset   Asset       @relation("TradeOrderBaseAsset", fields: [baseAssetId], references: [id], onDelete: Restrict)
  quoteAsset  Asset       @relation("TradeOrderQuoteAsset", fields: [quoteAssetId], references: [id], onDelete: Restrict)
  lockedAsset Asset       @relation("TradeOrderLockedAsset", fields: [lockedAssetId], references: [id], onDelete: Restrict)

  makerTrades Trade[] @relation("TradeMakerOrder")
  takerTrades Trade[] @relation("TradeTakerOrder")

  @@index([userId])
  @@index([tradingPairId, side, status, price, createdAt])
  @@index([status])
  @@index([createdAt])
}

model Trade {
  id String @id @default(cuid())

  tradingPairId String
  baseAssetId   String
  quoteAssetId  String

  makerOrderId String
  takerOrderId String

  buyerUserId  String
  sellerUserId String

  price    Decimal @db.Decimal(36, 18)
  quantity Decimal @db.Decimal(36, 18)

  quoteAmount Decimal @db.Decimal(36, 18)

  buyerFeeAssetId  String?
  buyerFeeAmount   Decimal @default(0) @db.Decimal(36, 18)
  sellerFeeAssetId String?
  sellerFeeAmount  Decimal @default(0) @db.Decimal(36, 18)

  makerSide TradeOrderSide
  takerSide TradeOrderSide

  idempotencyKey String @unique @db.VarChar(180)

  createdAt DateTime @default(now())

  tradingPair TradingPair @relation(fields: [tradingPairId], references: [id], onDelete: Restrict)
  baseAsset   Asset       @relation("TradeBaseAsset", fields: [baseAssetId], references: [id], onDelete: Restrict)
  quoteAsset  Asset       @relation("TradeQuoteAsset", fields: [quoteAssetId], references: [id], onDelete: Restrict)

  makerOrder TradeOrder @relation("TradeMakerOrder", fields: [makerOrderId], references: [id], onDelete: Restrict)
  takerOrder TradeOrder @relation("TradeTakerOrder", fields: [takerOrderId], references: [id], onDelete: Restrict)

  buyer  User @relation("TradeBuyer", fields: [buyerUserId], references: [id], onDelete: Restrict)
  seller User @relation("TradeSeller", fields: [sellerUserId], references: [id], onDelete: Restrict)

  buyerFeeAsset  Asset? @relation("TradeBuyerFeeAsset", fields: [buyerFeeAssetId], references: [id], onDelete: Restrict)
  sellerFeeAsset Asset? @relation("TradeSellerFeeAsset", fields: [sellerFeeAssetId], references: [id], onDelete: Restrict)

  @@index([tradingPairId, createdAt])
  @@index([buyerUserId])
  @@index([sellerUserId])
  @@index([makerOrderId])
  @@index([takerOrderId])
  @@index([createdAt])
}

model MarketCandle {
  id String @id @default(cuid())

  tradingPairId String

  interval String @db.VarChar(20)

  openTime  DateTime
  closeTime DateTime

  open  Decimal @db.Decimal(36, 18)
  high  Decimal @db.Decimal(36, 18)
  low   Decimal @db.Decimal(36, 18)
  close Decimal @db.Decimal(36, 18)

  volume      Decimal @default(0) @db.Decimal(36, 18)
  quoteVolume Decimal @default(0) @db.Decimal(36, 18)

  tradeCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tradingPair TradingPair @relation(fields: [tradingPairId], references: [id], onDelete: Restrict)

  @@unique([tradingPairId, interval, openTime])
  @@index([tradingPairId, interval, openTime])
  @@index([interval, openTime])
}
